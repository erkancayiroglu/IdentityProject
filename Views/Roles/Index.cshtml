@model IEnumerable<RoleWithUsersViewModel> //Değiştirmiş olduk normalde Identity User model ismi kullanıyorduk

<a class="btn btn-primary" asp-action="Create">Create Role</a>


<table class="table table-sm table-bordered">
	<tr>
		<th>Id</th>
		<th>Rol Adı</th>
		<th>Kullanıcılar</th>
		<th style="width:125px;"></th>

	</tr>

    @if (!Model.Any())
    {
        <tr><td colspan="4" class="text-center">Role Yok</td></tr>
    }

    @foreach (var roleWithUsers in Model)
    {
        <tr>
            <td>@roleWithUsers.Role.Id</td> <!--Role nesnesinde  Id parametresine gidiuor-->
            <td>@roleWithUsers.Role.Name</td>
            <td>
                @if (roleWithUsers.Users.Any())
                {
                    @foreach (var user in roleWithUsers.Users)
                    {
                        <div>@user.UserName</div>
                    }
                }
                else
                {
                    <span>Bu rolde hiç kullanıcı yok.</span>
                }
            </td>
            <td>
               
                    <a class="btn btn-primary" asp-controller="Roles" asp-action="Edit" asp-route-id="@roleWithUsers.Role.Id">Edit</a>
                    <form asp-controller="Roles" asp-action="Delete"  method="post" onsubmit="return confirm('Emin misiniz?')" style="display:inline-block;">
                        <input type="hidden" name="id" value="@roleWithUsers.Role.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                
            </td>
        </tr>
    }

</table>