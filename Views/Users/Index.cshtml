@model IEnumerable<AppUser>


<h2>User List</h2>
<br /> 
<a href="/Account/Create" class="btn btn-primary mb-1">User Create</a>
	<table class="table">
	<thead>
	<tr>
		<td>Id</td>
		<td>Name</td>
		<td>Email</td>
		<td></td>

	</tr>
	</thead>
	<tbody>
	@foreach(var user in Model ){
		
	<tr>
		<td>@user.Id</td>  <!-- Burada Displayde olutyorö-->
		<td>@user.UserName</td>
		<td>@user.Email</td>
		<td>
					<a asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Edit</a>
					<form asp-action="Delete" method="post" onsubmit="return confirm('Emin misiniz?')" style="display:inline-block;">
						<input type="hidden" name="id" value="@user.Id" />
						<button type="submit" class="btn btn-danger btn-sm">Delete</button>
					</form>
		</td>

	</tr>
		

	}

	</tbody>


</table>	
	
